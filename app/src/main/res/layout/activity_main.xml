<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".controller.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TÍTULO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minha Carteira"
            android:textColor="#111111"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- CARD REAL -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- ÍCONE -->

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="#DDF5DD"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/real"
                        app:tint="#0E6B2D"/>
                </LinearLayout>

                <!-- TEXTOS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Real"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#111111"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moeda nacional"
                        android:textColor="#888888"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/txtReal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 100.000,00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#0E6B2D"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- TAG -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BRL"
                    android:textStyle="bold"
                    android:textColor="#0E6B2D"
                    android:background="#DDF5DD"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD DÓLAR -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="#DDE7F8"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/dolar"
                        app:tint="#2454A6"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dólar Americano"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#111111"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moeda estrangeira"
                        android:textColor="#888888"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/txtDollar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 50.000,00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#2454A6"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USD"
                    android:textStyle="bold"
                    android:textColor="#2454A6"
                    android:background="#DDE7F8"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD BITCOIN -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="#FFF0D9"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/bitcoin"
                        app:tint="#F39C12"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bitcoin"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#111111"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Criptomoeda"
                        android:textColor="#888888"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/txtBitcoin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.500000 BTC"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#F39C12"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BTC"
                    android:textStyle="bold"
                    android:textColor="#D68910"
                    android:background="#FFF0D9"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BOTÃO -->

        <Button
            android:id="@+id/btnConverter"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Converter Recursos"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B8E3E"/>

    </LinearLayout>

</ScrollView>